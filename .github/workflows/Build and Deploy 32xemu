name: Build and Deploy 32xemu

on:
  push:
    branches: [ "main" ]
  workflow_dispatch:

permissions:
  contents: write
  pages: write
  id-token: write

jobs:
  build:
    runs-on: ubuntu-latest
    steps:

      - name: Checkout
        uses: actions/checkout@v4

      - name: Create ZIP of 32xemu files
        run: |
          mkdir output
          cd 32xemu
          zip -r ../output/32xemu.zip .

      - name: Copy website files
        run: |
          cp -r 32xemu output/site

      - name: Upload artifact to Pages
        uses: actions/upload-pages-artifact@v3
        with:
          path: output/site

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}

    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
